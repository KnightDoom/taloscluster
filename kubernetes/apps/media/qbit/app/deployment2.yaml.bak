  name: qbit
  namespace: media
  resourceVersion: "15847378"
  uid: 5d8585ee-b9c9-4e84-ada0-11bb8da78156
spec:
  progressDeadlineSeconds: 600
  replicas: 1
  revisionHistoryLimit: 3
  selector:
    matchLabels:
      app.kubernetes.io/controller: qbit
      app.kubernetes.io/instance: qbit
      app.kubernetes.io/name: qbit
  strategy:
    type: Recreate
  template:
    metadata:
      labels:
        app.kubernetes.io/controller: qbit
        app.kubernetes.io/instance: qbit
        app.kubernetes.io/name: qbit
    spec:
      automountServiceAccountToken: true
      containers:
      - env:
        - name: QBT_TORRENTING_PORT
          value: "25656"
        - name: QBT_WEBUI_PORT
          value: "10095"
        - name: TZ
          value: America/New_York
        - name: portNum
          value: "10095"
        image: ghcr.io/home-operations/qbittorrent:5.2.0@sha256:788796013c3da75f2dba568c5319975a5c41f555586dfd13987be4631181e00e
        imagePullPolicy: IfNotPresent
        livenessProbe:
          failureThreshold: 3
          httpGet:
            path: /
            port: 10095
            scheme: HTTP
          initialDelaySeconds: 10
          periodSeconds: 10
          successThreshold: 1
          timeoutSeconds: 1
        name: app
        readinessProbe:
          failureThreshold: 3
          httpGet:
            path: /
            port: 10095
            scheme: HTTP
          initialDelaySeconds: 10
          periodSeconds: 10
          successThreshold: 1
          timeoutSeconds: 1
        resources:
          limits:
            memory: 4Gi
          requests:
            cpu: 100m
            memory: 200Mi
        securityContext:
          allowPrivilegeEscalation: false
          capabilities:
            drop:
            - ALL
          readOnlyRootFilesystem: true
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
        volumeMounts:
        - mountPath: /config
          name: config
        - mountPath: /library
          name: media
        - mountPath: /incomplete
          name: qbit-incomplete
        - mountPath: /tmp
          name: tmp
      - env:
        - name: STAKATER_QBIT_INFO_SECRET
          value: d83ec8be1f04fe5b8d78d1197a59c79885b26ad1
        - name: portNum
          value: "8080"
        - name: VPN_TYPE
          value: wireguard
        - name: VPN_INTERFACE
          value: wg0
        - name: VPN_SERVICE_PROVIDER
          value: custom
        - name: WIREGUARD_PRIVATE_KEY
          valueFrom:
            secretKeyRef:
              key: nordwg
              name: qbit-info
        - name: WIREGUARD_ENDPOINT_IP
          value: 191.96.36.182
        - name: WIREGUARD_ENDPOINT_PORT
          value: "1337"
        - name: WIREGUARD_PUBLIC_KEY
          value: Y3tte8XLDa9ETytANtW8thD2U0BQ9jaERjGme2XAy0g=
        - name: WIREGUARD_ADDRESSES
          value: 10.28.240.65/32
        - name: FIREWALL_INPUT_PORTS
          value: "10095"
        - name: FIREWALL_OUTBOUND_SUBNETS
          value: 10.96.0.0/16,10.69.0.0/16
        - name: TZ
          value: America/New_York
        - name: DNS_ADDRESS
          value: 10.0.0.243
        - name: BLOCK_MALICIOUS
          value: "off"
        image: ghcr.io/qdm12/gluetun:latest
        imagePullPolicy: Always
        name: gluetun
        resources:
          limits:
            memory: 4Gi
            squat.ai/tun: "1"
          requests:
            cpu: 100m
            memory: 100Mi
        securityContext:
          allowPrivilegeEscalation: false
          capabilities:
            add:
            - NET_ADMIN
            - NET_RAW
          readOnlyRootFilesystem: false
          runAsNonRoot: false
          runAsUser: 0
        terminationMessagePath: /dev/termination-log
        terminationMessagePolicy: File
        volumeMounts:
        - mountPath: /config
          name: config
        - mountPath: /library
          name: media
        - mountPath: /incomplete
          name: qbit-incomplete
        - mountPath: /tmp
          name: tmp
      dnsPolicy: ClusterFirst
      enableServiceLinks: false
      restartPolicy: Always
      schedulerName: default-scheduler
      securityContext:
        fsGroup: 1000
        fsGroupChangePolicy: OnRootMismatch
        runAsGroup: 1000
        runAsNonRoot: true
        runAsUser: 1000
        seccompProfile:
          type: RuntimeDefault
      serviceAccount: default
      serviceAccountName: default
      terminationGracePeriodSeconds: 30
      volumes:
      - name: config
        persistentVolumeClaim:
          claimName: qbit
      - name: media
        nfs:
          path: /PlexLib
          server: 192.168.86.9
      - name: qbit-incomplete
        persistentVolumeClaim:
          claimName: qbit-incomplete
      - emptyDir: {}
        name: tmp
